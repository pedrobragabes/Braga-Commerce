generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  logoUrl   String?
  whatsapp  String?
  email     String?
  address   String?
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  customers  Customer[]
  categories Category[]
  products   Product[]
  orders     Order[]
  settings   StoreSettings?
  emailOutbox EmailOutbox[]
}

model StoreSettings {
  id                    String   @id @default(cuid())
  storeId               String   @unique
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  primaryColor          String?
  secondaryColor        String?
  currency              String   @default("BRL")
  allowLocalPickup      Boolean  @default(true)
  allowLocalDelivery    Boolean  @default(false)
  localDeliveryFeeCents Int?
  freeShippingFromCents Int?
  mercadoPagoPublicKey  String?
  mercadoPagoEnabled    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id         String   @id @default(cuid())
  authUserId String?  @unique
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name       String
  email      String   @unique
  role       UserRole @default(ADMIN)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId, role])
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

model Category {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([storeId, slug])
}

model Product {
  id               String           @id @default(cuid())
  storeId          String
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name             String
  slug             String
  description      String?
  shortDescription String?
  sku              String?
  basePriceCents   Int
  stockQuantity   Int              @default(0)
  compareAtCents   Int?
  isActive         Boolean          @default(true)
  isFeatured       Boolean          @default(false)
  hasVariants      Boolean          @default(false)
  images           ProductImage[]
  variants         ProductVariant[]
  orderItems       OrderItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([storeId, slug])
}

model ProductImage {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String
  storagePath String? @unique
  alt         String?
  sortOrder   Int     @default(0)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  size          String?
  color         String?
  priceCents    Int?
  stockQuantity Int         @default(0)
  isActive      Boolean     @default(true)
  orderItems    OrderItem[]

  @@unique([productId, sku])
}

model Customer {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  authUserId String?
  name       String
  email      String?
  phone      String
  document   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@unique([storeId, phone])
  @@unique([storeId, authUserId])
  @@index([storeId, email])
}

model Order {
  id                       String            @id @default(cuid())
  storeId                  String
  store                    Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customerId               String
  customer                 Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status                   OrderStatus       @default(PENDING)
  paymentStatus            PaymentStatus    @default(WAITING_PAYMENT)
  fulfillmentStatus        FulfillmentStatus @default(NOT_FULFILLED)
  subtotalCents            Int
  shippingCents            Int               @default(0)
  discountCents            Int               @default(0)
  totalCents               Int
  deliveryMethod           DeliveryMethod    @default(LOCAL_PICKUP)
  customerName             String
  customerPhone            String
  customerEmail            String?
  shippingZipCode          String?
  shippingStreet           String?
  shippingNumber           String?
  shippingComplement       String?
  shippingNeighborhood     String?
  shippingCity             String?
  shippingState            String?
  mercadoPagoPreferenceId  String?
  mercadoPagoPaymentId     String?
  notes                    String?
  internalNote             String?
  items                    OrderItem[]
  paymentEvents            PaymentEvent[]
  emailOutbox              EmailOutbox[]
  inventoryStatus          InventoryStatus   @default(NOT_RESERVED)
  reservedAt               DateTime?
  expiresAt                DateTime?
  stockCommittedAt         DateTime?
  stockReleasedAt          DateTime?
  paidAt                   DateTime?
  cancelledAt              DateTime?
  refundedAt               DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([storeId, status])
  @@index([customerId])
  @@index([mercadoPagoPaymentId])
  @@index([inventoryStatus, expiresAt])
  @@index([storeId, paidAt])
}

enum InventoryStatus {
  NOT_RESERVED
  RESERVED
  COMMITTED
  RELEASED
  REQUIRES_REVIEW
}

model PaymentEvent {
  id              String   @id @default(cuid())
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  eventKey         String   @unique
  provider         String
  providerEventId  String
  providerStatus   String
  eventType        String
  result           String
  requestId        String?
  processedAt      DateTime?
  createdAt        DateTime @default(now())

  @@index([orderId])
  @@index([provider, providerEventId])
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName    String
  variantName    String?
  sku            String?
  quantity       Int
  unitPriceCents Int
  totalCents     Int
}

model RateLimitBucket {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model EmailOutbox {
  id            String         @id @default(cuid())
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventKey      String         @unique
  type          EmailType
  status        EmailStatus    @default(PENDING)
  attempts      Int            @default(0)
  nextAttemptAt DateTime       @default(now())
  sentAt        DateTime?
  lastErrorCode String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, nextAttemptAt])
  @@index([orderId])
}

enum EmailType {
  ORDER_CREATED
  PAYMENT_CONFIRMED
  ORDER_CANCELLED
  PAYMENT_REFUNDED
}

enum EmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  WAITING_PAYMENT
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  NOT_FULFILLED
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  LOCAL_PICKUP
  LOCAL_DELIVERY
  SHIPPING
}
