# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Acesso temporário ao beta (somente server-side; deixe vazio no desenvolvimento)
SITE_ACCESS_PASSWORD=
SITE_ACCESS_SECRET=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/braga_commerce?schema=public

# Supabase Auth do painel (Milestone 4)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bootstrap inicial do operador (somente para npm run admin:bootstrap)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrador PV Moda
ADMIN_ROLE=OWNER

# Mercado Pago Checkout Pro (Milestone 3)
MERCADO_PAGO_ENV=sandbox
MERCADO_PAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# Storage de imagens de produto (Milestone 5)
STORAGE_BUCKET=product-images

# Store seed
SEED_STORE_NAME=PV Moda Masculina
SEED_STORE_SLUG=pv-moda-masculina
SEED_STORE_WHATSAPP=
SEED_ALLOW_LOCAL_DELIVERY=true
SEED_LOCAL_DELIVERY_FEE_CENTS=0
